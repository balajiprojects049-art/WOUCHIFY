{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/events", "destination": "/api/events" },
    { "source": "/api/poll", "destination": "/api/poll" },
    { "source": "/api/data", "destination": "/api/data" },
    { "source": "/api/sync", "destination": "/api/sync" },
    { "source": "/api/:path*", "destination": "/api/collection/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

